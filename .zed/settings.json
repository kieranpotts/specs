{
  /* Vertical guidelines for line wrapping. */
  "wrap_guides": [80, 100, 120, 140, 160],

  /* By default, wrap long lines at the viewport or
  120 characters, whichever is narrowest. */
  "soft_wrap": "bounded",
  "preferred_line_length": 120,

  "languages": {

    /* Wrap documentation files at the viewport width. Most AsciiDoc and
    Markdown lines should be hard-wrapped at 80, anyway. Exceptions allowed
    for tables and long URLs.  */
    "Markdown": {
      "soft_wrap": "editor_width"
    }

  }
}
